{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,

    "types": ["vite/client"],
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src"]
}
